STATUS_PORT=7999
STATUS_DB=/opt/status/status.db
STATUS_TOKEN=
RUST_LOG=info

# Anti-abuse for /links/apply
LINK_CAPTCHA_PROVIDER=none
LINK_TURNSTILE_SITE_KEY=
LINK_TURNSTILE_SECRET=
LINK_HCAPTCHA_SITE_KEY=
LINK_HCAPTCHA_SECRET=
LINK_APPLY_RATE_LIMIT_WINDOW_SEC=3600
LINK_APPLY_RATE_LIMIT_MAX=3
LINK_BLOCK_DISPOSABLE_EMAIL=true
LINK_BLOCK_EDU_GOV_EMAIL=true
LINK_APPLY_DENY_HOSTS=aliyun.com,qq.com,baidu.com

# review-reporter title similarity guard
REVIEW_TITLE_SIM_PENDING_BELOW=0.35
REVIEW_TITLE_SIM_REJECT_BELOW=0.18
